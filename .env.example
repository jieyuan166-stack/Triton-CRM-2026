# =============================================================================
# Triton CRM — Environment Variables Template
# Copy to .env.local and fill in real values. .env.local is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER-ONLY SECRETS — NEVER expose to the client, never commit real values
# -----------------------------------------------------------------------------

# Gmail SMTP App Password (16 chars, from Google Account → Security → App passwords)
# Used by the email service in lib/email-service.ts (server-side only).
SMTP_PASSWORD=""

# NextAuth signing secret (Step 10).
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
AUTH_SECRET=""

# Database connection string (Step 10, Prisma).
# Default for local dev: file-based SQLite.
DATABASE_URL="file:./data/triton.db"

# Initial admin seed (Step 10, used by prisma/seed.ts ONLY on first install)
SEED_ADMIN_EMAIL="your-email@example.com"
SEED_ADMIN_PASSWORD=""

# Cloudflare Tunnel token (Step 12, NAS deployment only)
CLOUDFLARED_TOKEN=""

# -----------------------------------------------------------------------------
# PUBLIC / NON-SECRET — these can also be set per environment.
# Override via the Settings UI is preferred for the SMTP_* fields below;
# treat the values here as fallbacks/bootstrap defaults.
# -----------------------------------------------------------------------------

# NextAuth public URL (Step 10)
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Email service defaults (overridable from Settings → Email Configuration)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@example.com"
SMTP_FROM_NAME="Your Name"
SMTP_FROM_EMAIL="your-email@example.com"

# Google Maps / Places API key (browser-side, hence NEXT_PUBLIC_ prefix).
# Get one at https://console.cloud.google.com/apis/credentials and enable
# the "Maps JavaScript API" + "Places API". Restrict the key by HTTP referrer.
# Leaving this blank gracefully disables address autocomplete — the input
# falls back to a plain text field.
GOOGLE_MAPS_API_KEY=""

CRON_SECRET=change-me-to-a-long-random-secret

# Disaster-recovery control-plane secret. It signs admin requests written to
# the NAS-only restore queue. Generate separately from CRON_SECRET.
BACKUP_CONTROL_SECRET=change-me-to-another-long-random-secret

# NAS disaster-recovery notification transport. Keep real values only in the
# NAS .env.production (mode 600), never in Git.
BACKUP_EMAIL_TO="your-backup-email@example.com"
BACKUP_SMTP_HOST="smtp.gmail.com"
BACKUP_SMTP_PORT="465"
BACKUP_SMTP_SECURE="true"
BACKUP_SMTP_USER="your-email@example.com"
BACKUP_SMTP_PASSWORD=""
BACKUP_SMTP_FROM_EMAIL="your-email@example.com"
BACKUP_SMTP_FROM_NAME="Triton CRM Backup"

# Full backup secrets stay in backup-secrets/backup.env on the NAS, not here.
# See backup-secrets/README.md for the required B2, age, and SMTP fields.

CLAIRE_SMTP_PASSWORD=your-claire-gmail-app-password
