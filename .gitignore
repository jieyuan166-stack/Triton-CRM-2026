# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/prisma/data/
/prisma/*.db
/prisma/*.db-*

# runtime artifacts on the NAS
tunnel-watchdog.log
/cloudflared/

# Full encrypted disaster-recovery runtime data and private NAS secrets.
/disaster-recovery/*
!/disaster-recovery/.gitkeep
/.github-sync/
/backup-secrets/*
!/backup-secrets/README.md
/uploads/

# misc
.DS_Store
._*
.cache/
*.pem

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets MUST stay local; .env.example is the shared template
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
__pycache__/
